# FlowMind AI — Frontend Environment Variables
# Copy this file to .env.local (for local dev) or .env.production (for prod).
# NEVER commit files with real API keys to version control.

# Backend API base URL
VITE_API_URL=http://localhost:8000

# Google Maps JavaScript API key
# Enable "Maps JavaScript API" + "Visualization library" in GCP console.
# Leave empty to use the built-in CSS stadium map instead.
VITE_GOOGLE_MAPS_API_KEY=your_maps_api_key_here

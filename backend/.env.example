# FlowMind AI — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Gemini AI ────────────────────────────────────────────────────────────────
# Get your key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Firebase Realtime Database ────────────────────────────────────────────────
# Create a project at https://console.firebase.google.com
# Leave empty to use the in-memory mock database instead
FIREBASE_DATABASE_URL=your_firebase_url_here

# ── Google Cloud ──────────────────────────────────────────────────────────────
# Your GCP project ID (used for Cloud Logging)
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# ── Google Maps ───────────────────────────────────────────────────────────────
# Enable "Maps JavaScript API" + "Visualization API" in your GCP console
GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Stadium Configuration ─────────────────────────────────────────────────────
STADIUM_NAME=MetaStadium Arena
STADIUM_CAPACITY=60000
MOCK_UPDATE_INTERVAL=30

# ── Alert Thresholds ──────────────────────────────────────────────────────────
DENSITY_WARNING_THRESHOLD=0.75
DENSITY_CRITICAL_THRESHOLD=0.90

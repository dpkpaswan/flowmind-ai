# FlowMind AI -- Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# Sensitive values should be loaded from Google Cloud Secret Manager in production.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=FlowMind AI
APP_VERSION=1.0.0
DEBUG=true

# ── Gemini AI (Vertex AI SDK) ────────────────────────────────────────────────
# Uses Application Default Credentials (ADC) -- no API key needed on Cloud Run.
# Set GOOGLE_CLOUD_PROJECT below for Vertex AI to work.
GEMINI_MODEL=gemini-2.5-flash
VERTEX_AI_LOCATION=us-central1

# ── Firebase Realtime Database ───────────────────────────────────────────────
# Create a project at https://console.firebase.google.com
# Leave empty to use the in-memory mock database instead
FIREBASE_DATABASE_URL=

# ── Google Cloud ─────────────────────────────────────────────────────────────
# Your GCP project ID (used for Vertex AI, BigQuery, Cloud Logging,
# Cloud Monitoring, Pub/Sub, Secret Manager, Cloud Storage)
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# ── Google Maps ──────────────────────────────────────────────────────────────
# Enable "Maps JavaScript API" + "Visualization API" in your GCP console
GOOGLE_MAPS_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# In production, set to your Cloud Run frontend URL
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── BigQuery Analytics ───────────────────────────────────────────────────────
# BigQuery dataset for crowd event analytics (created automatically)
BIGQUERY_DATASET=flowmind_analytics

# ── Stadium Configuration ───────────────────────────────────────────────────
STADIUM_NAME=MetaStadium Arena
STADIUM_CAPACITY=60000
MOCK_UPDATE_INTERVAL=30

# ── Alert Thresholds ────────────────────────────────────────────────────────
DENSITY_WARNING_THRESHOLD=0.75
DENSITY_CRITICAL_THRESHOLD=0.90
WAIT_WARNING_MINUTES=10
WAIT_CRITICAL_MINUTES=20

# ── Performance Tuning ──────────────────────────────────────────────────────
SNAPSHOT_CACHE_TTL=10
GZIP_MINIMUM_SIZE=500

# ── Security ────────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_CHAT_PER_MINUTE=20
MAX_CHAT_MESSAGE_LENGTH=500
